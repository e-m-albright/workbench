#!/usr/bin/env bash
# research — deep-research runs on the Hermes kanban swarm.
#
# Thin wrapper: all orchestration state lives in Hermes' kanban SQLite board;
# run artifacts live in ~/.research/runs/<slug>/. This script only seeds runs,
# ticks the dispatcher, and surfaces results.
#
# Usage:
#   research start "<question>" [--strategy breadth|hypothesis|storm] [--diver-cards N]
#   research go    "<question>"   # start + daemon until done (burst mode)
#   research tick                 # one idempotent dispatch pass
#   research watch                # live board
#   research status               # board summary + run dirs
#   research report [slug]        # print latest (or named) report
set -euo pipefail

RUNS_DIR="${RESEARCH_RUNS_DIR:-$HOME/.research/runs}"
cmd="${1:-}"; shift || true

slugify() { printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+|-+$//g' | cut -c1-60; }

start_run() {
  local question="$1"; shift
  local strategy="breadth-survey"
  while [[ $# -gt 0 ]]; do case "$1" in
    --strategy) case "$2" in breadth) strategy="breadth-survey";; hypothesis) strategy="hypothesis-driven";; storm) strategy="storm-perspectives";; *) strategy="$2";; esac; shift 2;;
    *) echo "unknown flag: $1" >&2; exit 2;;
  esac; done

  local slug run_dir
  slug="$(slugify "$question")-$(date +%m%d%H%M)"
  run_dir="$RUNS_DIR/$slug"
  mkdir -p "$run_dir"
  cat > "$run_dir/run.yaml" <<EOF
question: "$question"
strategy: $strategy
started: $(date -Iseconds)
profiles: {scout: claude-haiku-4.5, diver: claude-sonnet-4.6, skeptic: claude-haiku-4.5, synthesist: claude-opus-4.8}
verify: {min_sources: 2, default_verdict: refuted}
stop: {max_rounds: 3, dry_rounds: 2, insight_gate: on}
EOF

  hermes kanban init >/dev/null
  # Swarm scaffold: parallel workers -> verifier -> synthesizer, with card
  # bodies carrying the skill contracts and the run directory.
  hermes kanban swarm "Deep research: $question — strategy=$strategy. Planner contract: research-plan skill. All claims flow through the research-skeptic verdict protocol; the synthesist writes report.md to $run_dir and must pass the insight gate (on gate failure, file gap cards for another round, max 3 rounds). Run config: $run_dir/run.yaml" \
    --worker "scout:Survey the landscape per research-plan ($strategy) decomposition:research-plan,research-scout" \
    --worker "diver:Deep-dive primary sources for load-bearing and contested claims:research-diver" \
    --verifier skeptic \
    --synthesizer synthesist \
    --created-by default \
    --idempotency-key "$slug" \
    --json | tee "$run_dir/swarm.json"
  echo "run: $run_dir"
}

case "$cmd" in
  start) start_run "$@";;
  go)
    start_run "$@"
    echo "dispatching until board is quiet (Ctrl-C is safe; resume with: research tick)"
    # --force: standalone dispatcher (daemon is deprecated in favor of the
    # gateway's embedded dispatcher; we don't run the gateway on this machine).
    hermes kanban daemon --interval 30 --verbose --force
    ;;
  tick)   hermes kanban dispatch "$@";;
  watch)  hermes kanban watch;;
  status) hermes kanban list; echo; find "$RUNS_DIR" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort -r | head -5;;
  report)
    slug="${1:-$(find "$RUNS_DIR" -mindepth 1 -maxdepth 1 -type d | sort -r | head -1 | xargs basename)}"
    f="$RUNS_DIR/$slug/report.md"
    if [[ -f "$f" ]]; then cat "$f"; else echo "no report yet at $f (check: research status)"; exit 1; fi
    ;;
  *) sed -n '2,14p' "$0"; exit 2;;
esac
