{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.local/share/workbench/hooks/guard-sensitive-file.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $HOME/.local/share/workbench/hooks/guard-destructive-shell.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
