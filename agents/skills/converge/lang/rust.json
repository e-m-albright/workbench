{
  "language": "rust",
  "markers": ["Cargo.toml"],
  "files_glob": "**/*.rs",
  "run_from": ".",
  "suppression_patterns": {
    "allow-attr": "#\\[allow\\(",
    "unwrap-expect": "\\.unwrap\\(\\)|\\.expect\\(",
    "unsafe": "\\bunsafe \\{",
    "ignored-test": "#\\[ignore\\]",
    "todo-macro": "todo!\\(|unimplemented!\\(",
    "todo": "TODO|FIXME|XXX"
  },
  "tools": {
    "fmt": "cargo fmt",
    "lint": "cargo clippy -- -D warnings",
    "types": "cargo check",
    "test": "cargo test",
    "coverage": "cargo llvm-cov --fail-under-lines N",
    "complexity": "clippy cognitive-complexity-threshold",
    "mutation": "cargo mutants",
    "audit": "cargo audit"
  }
}
