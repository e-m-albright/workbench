{
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.6-sol",
  "defaultThinkingLevel": "medium",
  "doubleEscapeAction": "tree",
  "treeFilterMode": "user-only",
  "shellCommandPrefix": "shopt -s expand_aliases\neval \"$(grep '^alias ' $HOME/code/public/dotfiles/shell/.zshrc)\"",
  "defaultPreset": "dev",
  "safeGit": {
    "promptLevel": "high",
    "enabledByDefault": true
  },
  "discoveryTelemetry": {
    "enabledByDefault": true,
    "retentionDays": 7,
    "maxBytesPerDay": 5000000
  },
  "packages": [
    "npm:pi-mcp-adapter@2.11.0",
    "npm:pi-agent-browser-native@0.2.71"
  ],
  "lastChangelogVersion": "0.81.1",
  "theme": "dark"
}